API_PORT=8090
RPC_PORT=50051
# Use `localhost` when the Python worker runs on your host or is published via Docker.
# Use `py` when the Go API runs inside docker-compose.
RPC_PEER=localhost

# Optional: gRPC tuning (video inference can take a long time)
RPC_DIAL_TIMEOUT=240s
RPC_T2I_TIMEOUT=240s
RPC_I2V_TIMEOUT=30m
RPC_MAX_MSG_SIZE_MB=256
