# Copy to `.env` and fill in local values.
# Never commit your real `.env` (it may contain sensitive paths/tokens).

# BE Container
APP_ENV=dev
API_PORT=8090
API_ALLOWED_ORIGINS=*

# PY Container
RPC_PEER=py
RPC_PORT=50051
PY_PORT=50051

# Text-to-image model (either a `.safetensors` file or a local Diffusers directory)
# Used by docker-compose to set MODEL_PATH inside the Python container.
PY_MODEL_PATH=/workspace/models/<your-txt2img-model>.safetensors

# Optional override (Python will fall back to MODEL_PATH / PY_MODEL_PATH if unset)
TEXT_TO_IMAGE_MODEL_PATH=

# Optional: enable image-to-video by pointing at a Diffusers model directory
IMAGE_TO_VIDEO_MODEL_PATH=/workspace/models/<your-i2v-model-dir>

MODEL_MOUNT_PATH=/workspace/models
MODEL_LORA_PATH=
MODEL_HEIGHT=1024
MODEL_WIDTH=1024
MODEL_PROMPT_CHUNKING=0
# optional: brutal|words|phrases|sentences
MODEL_PROMPT_SPLIT_MODE=brutal

# FE Container
FE_PORT=3002
NEXT_PUBLIC_BASE_URL=http://localhost:8090
NEXT_PUBLIC_API_BASE_URL=http://localhost:8090
